DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/control_doc
PORT=3001

# Autenticación
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
SUPERADMIN_EMAIL=soporte@cognify.institute
SUPERADMIN_PASSWORD=cambia-esta-contraseña
# Dominios corporativos permitidos para iniciar sesión (separados por coma)
AUTH_ALLOWED_DOMAINS=shouxin.com.pe,cognify.institute

# Frontend (opcional): URL del API si no se sirve desde el mismo origen
# VITE_API_URL=https://api.tu-dominio.com

# ---------------------------------------------------------------------------
# Autosincronización del Excel de documentos (SharePoint/OneDrive)
# ---------------------------------------------------------------------------
# La configuración (enlace, hoja, organización, activado) se gestiona DESDE LA
# WEB APP, en el botón "🔄 Sincronización" (admin/superadmin). No hace falta
# tocar variables de entorno. Las de abajo son solo opcionales:
#
# Zona horaria de la ventana 08:00–18:00 (por defecto America/Lima).
# SYNC_TZ=America/Lima
# Fallback opcional del enlace si la BD no tuviera configuración (raro).
# SYNC_SHARE_URL=
