DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/control_doc
PORT=3001

# Autenticación
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
SUPERADMIN_EMAIL=soporte@cognify.institute
SUPERADMIN_PASSWORD=cambia-esta-contraseña
# Dominios corporativos permitidos para iniciar sesión (separados por coma)
AUTH_ALLOWED_DOMAINS=shouxin.com.pe,cognify.institute

# Frontend (opcional): URL del API si no se sirve desde el mismo origen
# VITE_API_URL=https://api.tu-dominio.com

# Recuperación de contraseña por correo
# URL pública de la app para construir el enlace del correo (si se omite, se
# deriva del propio request). Ej: https://control-doc.tu-dominio.com
# APP_URL=https://control-doc.tu-dominio.com
# Remitente de los correos
# MAIL_FROM=Control Doc <no-responder@tu-dominio.com>
#
# Opción A — Resend (HTTP, recomendado, sin dependencias de red SMTP):
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
#
# Opción B — SMTP (Gmail, Outlook, etc.):
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=usuario
# SMTP_PASS=contraseña
